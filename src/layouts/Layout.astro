---
// Layout.astro - 极简杂志风全局母版
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getSiteUrl } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = "一个关于设计、服务端工程与极简主义哲学的个人数字花园。只记录纯粹的创作与思想。",
  canonicalUrl: canonicalUrlProp,
  ogType = "website",
  publishedTime,
  structuredData
} = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeUrl = `${basePath}/`;
const writingUrl = `${basePath}/#blog`;
const aboutUrl = `${basePath}/about/`;
const pagePath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalPath = pagePath.startsWith(homeUrl) ? pagePath : `${basePath}${pagePath}`;
const canonicalUrl = canonicalUrlProp ?? new URL(canonicalPath, Astro.site ?? Astro.url).toString();
const isAboutPage = canonicalPath.startsWith(aboutUrl);
const isWritingPage = !isAboutPage;
const githubUrl = "https://github.com/Huaaa3188";
const rssUrl = getSiteUrl('rss.xml');
const jsonLd = structuredData ? JSON.stringify(structuredData).replace(/</g, '\\u003c') : undefined;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  
  <!-- 电影级跨页平滑转场机制 -->
  <ClientRouter />
  
  <!-- SEO Meta Tags -->
  <meta name="description" content={description}>
  <meta name="keywords" content="极简博客, 个人数字花园, Astro博客, 极简设计, 静态博客">
  <meta name="author" content="Lucid">
  <link rel="canonical" href={canonicalUrl}>
  <meta property="og:site_name" content="Lucid Hubble">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:type" content={ogType}>
  {publishedTime && <meta property="article:published_time" content={publishedTime}>}
  <meta name="twitter:card" content="summary">
  <link rel="alternate" type="application/rss+xml" title="Lucid Hubble" href={rssUrl}>
  {jsonLd && <script type="application/ld+json" set:html={jsonLd}></script>}
  
  <!-- Favicon (Fallback Emoji SVG) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌱</text></svg>">
  
  <!-- 立即检测暗黑模式并设置，防止页面出现闪烁 (FOUC) -->
  <script is:inline>
    const applyTheme = () => {
      const savedTheme = localStorage.getItem('theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      
      if (savedTheme === 'dark' || (!savedTheme && systemPrefersDark)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    };
    
    // 首屏物理载入时立即应用，防闪烁
    applyTheme();
    
    // 每次 Astro 跨页平滑转场 DOM 交换完成后立即重新补回，防止主题丢失
    document.addEventListener('astro:after-swap', applyTheme);
  </script>
</head>
<body>
  <div id="read-progress" class="read-progress"></div>
  <div class="container">
    <!-- Header -->
    <header class="site-header">
      <a href={homeUrl} class="logo">Lucid Hubble.</a>
      <nav class="nav-links">
        <a href={writingUrl} class={isWritingPage ? 'is-active' : undefined} aria-current={isWritingPage ? 'location' : undefined}>Writing</a>
        <a href={aboutUrl} class={isAboutPage ? 'is-active' : undefined} aria-current={isAboutPage ? 'page' : undefined} data-astro-prefetch>About</a>
        <!-- Dark Mode Toggle Button -->
        <button id="theme-toggle" class="theme-toggle" aria-label="切换暗黑模式">
          <!-- 图标将在客户端由 Lucide 动态渲染 -->
          <i data-lucide="moon"></i>
        </button>
      </nav>
    </header>

    <!-- Main Dynamic Content Slot -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div>
        &copy; 2026 Lucid Hubble. 记录工程、设计与日常思考。
      </div>
      <div class="footer-socials">
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <i data-lucide="github" class="footer-icon"></i>
        </a>
      </div>
    </footer>
  </div>

  <!-- Lucide Icons CDN (For crisp vector icons) -->
  <script is:inline src="https://unpkg.com/lucide@0.468.0/dist/umd/lucide.min.js"></script>

  <!-- 客户端主题切换绑定与 Lucide 图标初始化逻辑 -->
  <script>
    // 在客户端初始化 Lucide 图标
    function initIcons() {
      if ((window as any).lucide) {
        (window as any).lucide.createIcons();
      }
    }

    // 更新按钮状态图标
    function updateToggleIcon() {
      const themeToggleBtn = document.getElementById('theme-toggle');
      if (!themeToggleBtn) return;

      const currentTheme = document.documentElement.getAttribute('data-theme');
      
      if (currentTheme === 'dark') {
        themeToggleBtn.innerHTML = '<i data-lucide="sun"></i>';
        themeToggleBtn.setAttribute('aria-label', '切换至亮色模式');
      } else {
        themeToggleBtn.innerHTML = '<i data-lucide="moon"></i>';
        themeToggleBtn.setAttribute('aria-label', '切换至暗色模式');
      }

      initIcons();
    }

    // 绑定事件与初始化
    function initThemeToggle() {
      const themeToggleBtn = document.getElementById('theme-toggle');
      if (themeToggleBtn) {
        // 先移除可能残留的旧绑定，再重新绑定，避免 Astro 路由局部刷新导致多次绑定
        themeToggleBtn.removeEventListener('click', handleToggle);
        themeToggleBtn.addEventListener('click', handleToggle);
      }
      updateToggleIcon();
    }

    function handleToggle() {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
      
      updateToggleIcon();
    }

    function updateProgress() {
      const progressBar = document.getElementById('read-progress');
      if (!progressBar) return;

      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollPercent = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = `${scrollPercent}%`;
    }

    // 阅读进度条更新逻辑
    function initProgressBar() {
      const progressBar = document.getElementById('read-progress');
      if (!progressBar) return;

      // 先移除旧监听；updateProgress 是稳定引用，Astro 路由切换后可以正确解绑。
      window.removeEventListener('scroll', updateProgress);

      // 仅在详情页（即包含 <article> 容器的页面）上挂载滚动监听
      const isArticlePage = document.querySelector('article');
      if (!isArticlePage) {
        progressBar.style.width = '0%';
        return;
      }

      // 绑定滚动事件，先解绑以防重复绑定
      window.addEventListener('scroll', updateProgress);
      
      // 初始渲染时执行一次
      updateProgress();
    }

    // 适配 Astro View Transitions 的标准生命周期
    // 确保首屏加载及每一次跨页平滑转场完成后，所有动态交互与图标渲染顺利重置
    document.addEventListener('astro:page-load', () => {
      initIcons();
      initThemeToggle();
      initProgressBar();
    });
  </script>
</body>
</html>
