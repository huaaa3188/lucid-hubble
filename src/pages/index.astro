---
// index.astro - 博客主页
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. 异步获取 'blog' 内容集合里的所有文章，并过滤掉草稿（本地开发环境除外，方便预览）
const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV ? true : data.draft !== true;
});

// 2. 按时间倒序排序（最新的在最上面）
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 3. 辅助函数：格式化英文杂志日期
function formatDate(dateStr: string) {
  const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
  const dateObj = new Date(dateStr);
  return dateObj.toLocaleDateString('en-US', options);
}
---

<Layout title="Lucid Hubble - 极简主义数字花园">
  <!-- Hero / 简介 -->
  <section class="hero">
    <h1>思考的厚度，<br>藏在极简的设计与纯粹的文字中。</h1>
    <p>欢迎来到我的数字花园。这里没有喧嚣的算法推荐与杂乱的广告，只有独立写作的宁静与关于前端工程、极简设计及科技人文的纯粹文字记录。</p>
  </section>

  <!-- 博客文章列表 -->
  <section id="blog">
    <h3 class="section-title">RECENT WRITINGS</h3>
    
    <!-- 极简标签过滤提示条 -->
    <div id="filter-bar" class="filter-bar" style="display: none;">
      <span>正在检索分类: <strong id="active-tag"></strong></span>
      <button id="clear-filter" class="clear-btn">清除检索</button>
    </div>

    <div id="posts-list" class="posts-list">
      {sortedPosts.length === 0 ? (
        <p style="color: hsl(var(--fg-muted));">目前还没有发布任何文章。</p>
      ) : (
        sortedPosts.map((post, index) => {
          const { title, date, description, tags = [] } = post.data;
          
          return (
            <a 
              href={`/lucid-hubble/post/${post.id}`} 
              class="post-card" 
              style={`animation-delay: ${index * 0.15}s;`}
              data-tags={tags.join(',')}
              data-astro-prefetch
            >
              <div class="post-meta">
                <time datetime={date}>{formatDate(date)}</time>
                {tags.length > 0 && (
                  <>
                    <span>•</span>
                    {tags.map(tag => (
                      <span class="tag-btn" data-tag={tag}>#{tag}</span>
                    ))}
                  </>
                )}
              </div>
              <h2>{title}</h2>
              <p>{description}</p>
            </a>
          );
        })
      )}
    </div>
  </section>

</Layout>

<script>
  function initTagFilter() {
    const postsList = document.getElementById('posts-list');
    if (!postsList) return; // 不在主页则直接退出

    const filterBar = document.getElementById('filter-bar');
    const activeTagEl = document.getElementById('active-tag');
    const clearFilterBtn = document.getElementById('clear-filter');
    const postCards = document.querySelectorAll('.post-card');
    const tagBtns = document.querySelectorAll('.tag-btn');

    let currentTag = '';

    function filterTag(tag: string) {
      currentTag = tag;
      
      if (!tag) {
        // 清除筛选
        if (filterBar) filterBar.style.display = 'none';
        postCards.forEach(card => {
          (card as HTMLElement).style.display = 'block';
          (card as HTMLElement).style.opacity = '1';
          (card as HTMLElement).style.transform = 'translateY(0)';
        });
        return;
      }

      // 显示筛选条
      if (filterBar) filterBar.style.display = 'flex';
      if (activeTagEl) activeTagEl.textContent = `#${tag}`;

      postCards.forEach(card => {
        const tagsAttr = card.getAttribute('data-tags') || '';
        const tagsList = tagsAttr.split(',');
        if (tagsList.includes(tag)) {
          (card as HTMLElement).style.display = 'block';
          (card as HTMLElement).style.opacity = '1';
          (card as HTMLElement).style.transform = 'translateY(0)';
        } else {
          (card as HTMLElement).style.display = 'none';
          (card as HTMLElement).style.opacity = '0';
        }
      });
    }

    // 绑定事件
    tagBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        // 关键：阻止冒泡与超链接默认跳转行为
        e.preventDefault();
        e.stopPropagation();
        
        const tag = btn.getAttribute('data-tag') || '';
        filterTag(tag);
      });
    });

    if (clearFilterBtn) {
      clearFilterBtn.addEventListener('click', () => {
        filterTag('');
      });
    }
  }

  // 绑定 Astro 路由生命周期，完美支持 View Transitions
  document.addEventListener('astro:page-load', () => {
    initTagFilter();
  });
</script>
