---
// index.astro - 博客主页
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. 异步获取 'blog' 内容集合里的所有文章，并过滤掉草稿（本地开发环境除外，方便预览）
const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV ? true : data.draft !== true;
});

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

// 2. 按时间倒序排序（最新的在最上面）
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 3. 辅助函数：格式化英文杂志日期
function formatDate(date: Date) {
  const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
  return date.toLocaleDateString('en-US', options);
}
---

<Layout title="Lucid Hubble">
  <!-- Hero / 简介 -->
  <section class="hero">
    <h1>Lucid Hubble</h1>
    <p>服务端工程、工具折腾、读书与日常随笔。</p>
  </section>

  <!-- 博客文章列表 -->
  <section id="blog">
    <h3 class="section-title">RECENT WRITINGS</h3>
    
    <!-- 极简标签过滤提示条 -->
    <div id="filter-bar" class="filter-bar hidden">
      <span>正在检索分类: <strong id="active-tag"></strong></span>
      <button id="clear-filter" class="clear-btn">清除检索</button>
    </div>

    <div id="posts-list" class="posts-list">
      {sortedPosts.length === 0 ? (
        <p class="empty-state">目前还没有发布任何文章。</p>
      ) : (
        sortedPosts.map((post) => {
          const { title, date, description, tags = [] } = post.data;
          
          return (
            <article
              class="post-card" 
              data-tags={tags.join(',')}
            >
              <div class="post-meta">
                <time datetime={date.toISOString()}>{formatDate(date)}</time>
                {tags.length > 0 && (
                  <>
                    <span>•</span>
                    <div class="tag-list">
                      {tags.map(tag => (
                        <button type="button" class="tag-btn" data-tag={tag} aria-label={`按标签 ${tag} 筛选文章`}>#{tag}</button>
                      ))}
                    </div>
                  </>
                )}
              </div>
              <a href={`${basePath}/post/${post.id}/`} class="post-card-link" data-astro-prefetch>
                <h2>{title}</h2>
                <p>{description}</p>
              </a>
            </article>
          );
        })
      )}
    </div>
  </section>

</Layout>

<script>
  function initTagFilter() {
    const blogSection = document.getElementById('blog');
    if (!blogSection || blogSection.dataset.filterReady === 'true') return;
    blogSection.dataset.filterReady = 'true';

    const filterBar = document.getElementById('filter-bar');
    const activeTagEl = document.getElementById('active-tag');
    const clearFilterBtn = document.getElementById('clear-filter');
    const postCards = document.querySelectorAll('.post-card');

    function filterTag(tag: string) {
      if (!tag) {
        filterBar?.classList.add('hidden');
        postCards.forEach(card => {
          card.classList.remove('is-filtered-out');
        });
        return;
      }

      filterBar?.classList.remove('hidden');
      if (activeTagEl) activeTagEl.textContent = `#${tag}`;

      postCards.forEach(card => {
        const tagsAttr = card.getAttribute('data-tags') || '';
        const tagsList = tagsAttr.split(',');
        card.classList.toggle('is-filtered-out', !tagsList.includes(tag));
      });
    }

    blogSection.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const tagBtn = target?.closest('.tag-btn') as HTMLButtonElement | null;

      if (tagBtn) {
        const tag = tagBtn.getAttribute('data-tag') || '';
        filterTag(tag);
      }
    });

    clearFilterBtn?.addEventListener('click', () => filterTag(''));
  }

  // 绑定 Astro 路由生命周期，完美支持 View Transitions
  document.addEventListener('astro:page-load', () => {
    initTagFilter();
  });
</script>
